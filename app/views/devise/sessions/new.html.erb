<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rookie Coder Login</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-900 flex flex-col items-center min-h-screen justify-center">
    
    <!-- Container do Login -->
    <div class="p-8 rounded-lg shadow-lg w-[957px] h-[837px]">
        <h1 class="text-white text-3xl font-semibold text-center">
            Já é um <a href="#" class="text-teal-400 underline">aluno rookie</a>?
        </h1>
        <p class="text-gray-400 text-center mt-2">Faça o login e desbrave novos horizontes!</p>
        
        <div class="mt-6">
            <label class="block text-gray-300 text-lg" for="email">E-mail</label>
            <input type="email" id="email" class="w-[817px] h-[73px] bg-white border-3 border-white rounded-[13px] px-4 py-2 text-black placeholder-gray-400 focus:border-teal-400 focus:outline-none mt-2">
        </div>
        
        <div class="mt-4">
            <label class="block text-gray-300 text-lg" for="password">Senha</label>
            <input type="password" id="password" class="w-[817px] h-[73px] bg-white border-3 border-white rounded-[13px] px-4 py-2 text-black placeholder-gray-400 focus:border-teal-400 focus:outline-none mt-2">
        </div>
        
        <div class="flex items-center justify-end mt-4">
            <label class="flex items-center text-gray-300 text-sm">
                <input type="checkbox" class="mr-2"> Lembrar de mim
            </label>
        </div>
        
        <button class="w-full mt-6 bg-blue-500 hover:bg-blue-600 text-white font-semibold py-3 rounded-lg transition duration-300">Login</button>
        
        <div class="flex items-center my-4">
            <hr class="flex-grow border-gray-600">
            <span class="text-gray-400 mx-2">ou</span>
            <hr class="flex-grow border-gray-600">
        </div>
        
        <button class="w-full flex items-center justify-center border border-white text-white py-3 rounded-full transition duration-300 mb-2">
            <img src="https://img.icons8.com/color/24/000000/google-logo.png" class="mr-2"> Continuar com o Google
        </button>
        
        <button class="w-full flex items-center justify-center border border-white text-white py-3 rounded-full transition duration-300">
            <img src="https://img.icons8.com/ios-glyphs/24/ffffff/github.png" class="mr-2"> Continuar com o Github
        </button>
    </div>

</body>
</html>