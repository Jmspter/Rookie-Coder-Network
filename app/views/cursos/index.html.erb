<body class="bg-bg-dark text-white font-sans p-5">
    <main class="max-w-[1500px] mx-auto">
        <h1 class="text-4xl mb-4">Conheça <span class="text-highlight">nossos cursos</span>!</h1>
        
        <div class="flex gap-2 mb-8">
            <input type="text" class="flex-1 p-2 rounded bg-transparent border border-gray-600 text-white" placeholder="Buscar cursos...">
            <button class="bg-purple-btn text-white px-4 py-2 rounded">Opção de filtrar (Em dev)</button>
        </div>

        <section class="bg-card-bg rounded-lg p-10 text-center mb-8">
            <div class="mb-4">
                <h2 class="text-2xl">Anuncie aqui namoral ou recomendação<br>de algum curso</h2>
            </div>
            <div class="flex justify-center gap-1 mt-4">
                <span class="w-2 h-2 rounded-full bg-white"></span>
                <span class="w-2 h-2 rounded-full bg-gray-600"></span>
                <span class="w-2 h-2 rounded-full bg-gray-600"></span>
                <span class="w-2 h-2 rounded-full bg-highlight"></span>
                <span class="w-2 h-2 rounded-full bg-gray-600"></span>
                <span class="w-2 h-2 rounded-full bg-gray-600"></span>
            </div>
        </section>

        <section class="mb-8">
            <h2 class="text-lg mb-4">Recomendados para você</h2>
            <div class="flex items-center justify-center gap-4">
                <button class="bg-white bg-opacity-10 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-opacity-20">&lt;</button>
                <div class="flex gap-4 overflow-x-hidden w-[1389px]">
                    <% 3.times do %>
                        <div class="w-[463px] h-[228px] bg-card-bg rounded-lg flex-shrink-0"></div>
                    <% end %>
                </div>
                <button class="bg-white bg-opacity-10 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-opacity-20">&gt;</button>
            </div>
        </section>

        <section class="mb-8">
            <h2 class="text-lg mb-4">Cursos de Python</h2>
            <div class="flex items-center justify-center gap-4">
                <button class="bg-white bg-opacity-10 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-opacity-20">&lt;</button>
                <div class="flex gap-4 overflow-x-hidden w-[1389px]">
                    <% 3.times do %>
                        <div class="w-[463px] h-[228px] bg-card-bg rounded-lg flex-shrink-0"></div>
                    <% end %>
                </div>
                <button class="bg-white bg-opacity-10 text-white w-10 h-10 rounded-full flex items-center justify-center hover:bg-opacity-20">&gt;</button>
            </div>
        </section>
    </main>
    <script src="https://cdn.tailwindcss.com"></script>
    # aqui da para configurar variaveis para por as cores especificas(e se botar esse comentario dentro do script, buga que lagal);
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        highlight: '#84CC16',
                        'purple-btn': '#6A497F',
                        'bg-dark': '#1C1C1C',
                        'card-bg': '#2C2C2C',
                    }
                }
            }
        }
    </script>
</body>